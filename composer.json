{
	"name": "earth-app/mantle2",
	"description": "The drupal backend for The Earth App",
	"type": "project",
	"require": {
		"php": "^8.4",
		"drupal/core": "^11.3",
		"symfony/event-dispatcher": "^7.3",
		"drupal/json_field": "^1.4",
		"ext-json": "*",
		"ext-curl": "*",
		"drupal/key": "1.22.0",
		"symfony/rate-limiter": "^7.3",
		"symfony/cache": "^7.3",
		"drupal/smtp": "^1.4",
		"drupal/redis": "^1.10",
		"sebastian/diff": "^6",
		"drupal/openid_connect": "^3.0@alpha",
		"google/auth": "^1.50",
		"firebase/php-jwt": "^7.0.5",
		"stripe/stripe-php": "^20.3"
	},
	"autoload": {
		"psr-4": {
			"Drupal\\mantle2\\": "src/"
		}
	},
	"require-dev": {
		"drush/drush": "^13.7",
		"phpunit/phpunit": "^11.5",
		"drupal/core-dev": "^11.3",
		"phpstan/phpstan": "^2.2",
		"brianium/paratest": "^7.8"
	},
	"autoload-dev": {
		"psr-4": {
			"Drupal\\Tests\\mantle2\\": "tests/src/",
			"Drupal\\Tests\\": "vendor/drupal/core/tests/Drupal/Tests/",
			"Drupal\\KernelTests\\": "vendor/drupal/core/tests/Drupal/KernelTests/",
			"Drupal\\FunctionalTests\\": "vendor/drupal/core/tests/Drupal/FunctionalTests/",
			"Drupal\\TestTools\\": "vendor/drupal/core/tests/Drupal/TestTools/"
		}
	},
	"repositories": [
		{
			"type": "composer",
			"url": "https://packages.drupal.org/8"
		}
	],
	"config": {
		"allow-plugins": {
			"php-http/discovery": true,
			"phpstan/extension-installer": true,
			"tbachert/spi": true,
			"dealerdirect/phpcodesniffer-composer-installer": true,
			"drupal/core-composer-scaffold": false
		}
	}
}
