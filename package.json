{
	"name": "mantle2",
	"private": true,
	"scripts": {
		"prettier": "bunx prettier --write .",
		"prettier:check": "bunx prettier --check",
		"test": "./vendor/bin/phpunit",
		"test:unit": "./vendor/bin/phpunit --testsuite Unit",
		"test:integration": "./vendor/bin/paratest --testsuite Integration",
		"test:e2e": "./vendor/bin/phpunit --testsuite E2E",
		"test:coverage:unit": "./vendor/bin/phpunit --testsuite Unit --coverage-clover coverage/unit.clover.xml --coverage-text=coverage/mantle2.coverage.txt --log-junit coverage/unit.junit.xml",
		"test:coverage:integration": "./vendor/bin/paratest --testsuite Integration --coverage-clover coverage/integration.clover.xml --log-junit coverage/integration.junit.xml --coverage-text=coverage/integration.coverage.txt",
		"test:coverage:e2e": "./vendor/bin/phpunit --testsuite E2E --coverage-clover coverage/e2e.clover.xml --log-junit coverage/e2e.junit.xml --coverage-text=coverage/e2e.coverage.txt",
		"analyze": "./vendor/bin/phpstan --memory-limit=2G",
		"prepare": "husky install"
	},
	"devDependencies": {
		"@prettier/plugin-php": "^0.25.0",
		"@prettier/plugin-xml": "^3.4.2",
		"@types/bun": "latest",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.0",
		"prettier": "^3.8.2"
	},
	"peerDependencies": {
		"typescript": "^5.9.2 || ^6.0.0"
	},
	"lint-staged": {
		"*.{php,xml,dist,json,install,module,yml,md}": "prettier --write"
	}
}
