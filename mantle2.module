<?php

use Drupal\Core\Routing\RouteMatchInterface;
use Drupal\mantle2\Custom\Notification;
use Drupal\mantle2\Service\ApiKeysHelper;
use Drupal\mantle2\Service\ArticlesHelper;
use Drupal\mantle2\Service\CampaignHelper;
use Drupal\mantle2\Service\EventsHelper;
use Drupal\mantle2\Service\GeneralHelper;
use Drupal\mantle2\Service\PromptsHelper;
use Drupal\mantle2\Service\ReportsHelper;
use Drupal\mantle2\Service\UsersHelper;

function mantle2_help($route_name, RouteMatchInterface $route_match)
{
	switch ($route_name) {
		case 'help.page.mantle2':
			$output = '';
			$output .= '<h3>' . Drupal::translation()->translate('About') . '</h3>';
			$output .=
				'<p>' .
				Drupal::translation()->translate('The Drupal backend for The Earth App') .
				'</p>';
			return $output;

		default:
	}
}

function mantle2_get_list_id_header(?string $campaignId = null): string
{
	$subdomain = 'notifications';
	$listName = 'The Earth App Notifications';

	if (is_string($campaignId) && $campaignId !== '') {
		$slug = strtolower((string) preg_replace('/[^a-z0-9]+/i', '-', $campaignId));
		$slug = trim($slug, '-');

		if ($slug !== '') {
			$subdomain = $slug . '.notifications';
			$listName = 'The Earth App ' . ucwords(str_replace('-', ' ', $slug));
		}
	}

	return $listName . ' <' . $subdomain . '.earth-app.com>';
}

function mantle2_apply_list_headers(
	array &$message,
	array $params,
	?string $campaignId = null,
): void {
	$unsubscribeApiUrl = $params['unsubscribe_api_url'] ?? null;
	if (!is_string($unsubscribeApiUrl) || $unsubscribeApiUrl === '') {
		return;
	}

	$unsubscribeValues = ['<' . $unsubscribeApiUrl . '>'];

	$unsubscribeMailto =
		$params['unsubscribe_mailto'] ?? 'mailto:support@earth-app.com?subject=unsubscribe';
	if (is_string($unsubscribeMailto) && $unsubscribeMailto !== '') {
		if (!str_starts_with($unsubscribeMailto, 'mailto:')) {
			$unsubscribeMailto = 'mailto:' . $unsubscribeMailto;
		}

		$unsubscribeValues[] = '<' . $unsubscribeMailto . '>';
	}

	$message['headers']['List-Unsubscribe'] = implode(', ', $unsubscribeValues);
	$message['headers']['List-Unsubscribe-Post'] = 'List-Unsubscribe=One-Click';
	$message['headers']['List-ID'] = mantle2_get_list_id_header($campaignId);
	$message['headers']['List-Help'] = '<mailto:support@earth-app.com>';
	$message['headers']['List-Subscribe'] = '<mailto:support@earth-app.com?subject=subscribe>';
}

function mantle2_mail($key, &$message, $params)
{
	$message['from'] = Drupal::config('system.site')->get('mail');

	/** @var \Drupal\mantle2\Service\HTMLFactory $parser */
	$parser = Drupal::service('mantle2.parser');

	/** @var \Drupal\user\UserInterface $user */
	$user = $params['user'] ?? null;
	if (!$user) {
		Drupal::logger('mantle2')->error('No user object provided for email key: %key', [
			'%key' => $key,
		]);
		return;
	}
	$username = $user->getAccountName();

	// email campaigns that may include unsubscribe links
	if (str_starts_with($key, 'campaign:')) {
		$key = substr($key, 9);
		$campaign = CampaignHelper::getCampaign($key);

		if ($campaign) {
			if (isset($params['processed_campaign'])) {
				$campaign = $params['processed_campaign'];
			}

			// Ensure subject/body placeholders are always resolved at send time.
			$campaign = CampaignHelper::processCampaign($campaign, $user);

			$message['subject'] = $campaign['title'];
			$markdown = $campaign['body'];

			$message['body'][] = $parser->toHtml(
				$markdown,
				true,
				$params['unsubscribe_url'] ?? null,
			);

			mantle2_apply_list_headers($message, $params, $key);
			$message['headers']['Precedence'] = 'bulk';

			return;
		}
	}

	// determine if this email should include unsubscribe
	$includeUnsubscribe = in_array(
		$key,
		['new_login', 'new_password', 'oauth_provider_linked', 'oauth_provider_unlinked'],
		true,
	);
	$unsubscribeUrl = $params['unsubscribe_url'] ?? null; // Frontend URL for body link

	switch ($key) {
		case 'welcome':
			$message['subject'] = 'Welcome to The Earth App!';
			$markdown = "Hi @$username,\n\nWelcome to The Earth App! We're excited to have you on board. Explore the app to discover new insights, connect with others, and make a positive impact on our planet. If you have any questions or need assistance, feel free to reach out to our support team.\n\nLet's work together for a better Earth!";
			$message['body'][] = $parser->toHtml($markdown, false);
			break;
		case 'quest_challenge':
			$challenger = $params['challenger'] ?? 'A friend';
			$questTitle = $params['quest_title'] ?? 'a quest';
			$questLink =
				'https://app.earth-app.com/profile/quests?open=' . ($params['quest_id'] ?? '');
			$message['subject'] = "$challenger Challenged You to a Quest!";

			$markdown = "@$username, **{$challenger}** challenged you to the \"{$questTitle}\" quest on The Earth App!\n\n
			Think you're up for it? [Accept the challenge]({$questLink}) and start your quest now.";

			$message['body'][] = $parser->toHtml($markdown, false);
			break;
		case 'email_verification':
			$message['subject'] = 'The Earth App - Email Verification Code';

			$markdown = "Your email verification code is: **{$params['verification_code']}**\n\n
			This code will expire in 15 minutes.\n
			If you did not request this verification, please ignore this email.";

			$message['body'][] = $parser->toHtml($markdown, false);
			break;
		case 'login_verification':
			$message['subject'] = 'The Earth App - Sign-in Verification Code';

			$ip = $params['ip'] ?? 'unknown';
			$ua = $params['user_agent'] ?? 'Unknown Device';
			$time = $params['time'] ?? date(DATE_ATOM);
			$markdown = "@$username, A sign-in to your account was attempted from a new device or location.\n\n
			**Verification code:** **{$params['verification_code']}**\n\n
			This code will expire in 10 minutes.\n\n
			**Details:**\n
			- Time: {$time}\n
			- IP: {$ip}\n
			- User Agent: {$ua}\n\n
			If this was you, enter the code in the app to complete sign-in.\n
			If this wasn't you, **do not share this code** and please change your password immediately.";

			$message['body'][] = $parser->toHtml($markdown, false);
			break;
		case 'oauth_email_auto_set':
			$message['subject'] = 'The Earth App - Email Address Set';

			$providerName = ucfirst($params['provider'] ?? 'Unknown');
			$newEmail = $params['new_email'] ?? '';
			$markdown = "@$username, Your account did not have an email address on file. We've automatically set it to **{$newEmail}** using the address from your **{$providerName}** sign-in.\n\n
			You can change this at any time from your account settings.\n\n
			If this wasn't you, please secure your account immediately by unlinking the provider and updating your email.";

			$message['body'][] = $parser->toHtml($markdown, false);
			break;
		case 'new_login':
			$message['subject'] = 'The Earth App - New Login Notification';
			$markdown = "@$username, Your account was just used to log in from a new device or location.\n\n
			**Details:**\n
			- Time: {$params['time']}\n
			- IP: {$params['ip']} ({$params['additional_ips']})\n
			- User Agent: {$params['user_agent']}\n
			- Referrer: {$params['referer']}\n\n
			If this was you, you can safely ignore this email.\n
			If you did not log in, please reset your password immediately to secure your account.";

			$message['body'][] = $parser->toHtml($markdown, $includeUnsubscribe, $unsubscribeUrl);
			mantle2_apply_list_headers($message, $params, $key);
			break;
		case 'email_change_notification':
			$message['subject'] = 'The Earth App - Email Change Notification';

			$markdown = "@$username, Your email address was just requested to be changed.\n\n
			Old Email: **{$params['old_email']}**\n\n
			New Email: **{$params['new_email']}**\n\n
			If you did not perform this action, please contact support immediately to secure your account.";

			$message['body'][] = $parser->toHtml($markdown, false);
			break;
		case 'email_change_verification':
			$message['subject'] = 'The Earth App - Email Change Verification Code';

			$markdown = "Your email change verification code is: **{$params['verification_code']}**\n\n
			This code will expire in 15 minutes.\n
			If you did not request this verification, please ignore this email.";

			$message['body'][] = $parser->toHtml($markdown, false);
			break;
		case 'email_change_confirmed':
			$message['subject'] = 'The Earth App - Email Change Confirmation';

			$markdown = "@$username, Your email address has been successfully changed.\n\n
			Old Email: **{$params['old_email']}**\n\n
			New Email: **{$params['new_email']}**\n\n
			If you did not perform this action, please contact support immediately to secure your account.";

			$message['body'][] = $parser->toHtml($markdown, false);
			break;
		case 'password_reset':
			$message['subject'] = 'The Earth App - Password Reset';

			$markdown = "@$username, We received a request to reset your password for The Earth App.\n\n
			Click the link below to reset your password:\n
			{$params['reset_link']}\n\n
			This link will expire in 1 hour.\n\n
			If you did not request this password reset, please ignore this email and your password will remain unchanged.";

			$message['body'][] = $parser->toHtml($markdown, false);
			break;
		case 'new_password':
			$message['subject'] = 'The Earth App - Password Reset';

			$markdown = "@$username, Your password has been successfully changed.\n\n
				If you did not perform this action, please reset your password immediately to secure your account.";

			$message['body'][] = $parser->toHtml($markdown, $includeUnsubscribe, $unsubscribeUrl);
			mantle2_apply_list_headers($message, $params, $key);
			break;
		case 'oauth_provider_linked':
			$message['subject'] = 'The Earth App - OAuth Provider Linked';

			$providerName = ucfirst($params['provider'] ?? 'Unknown');
			$markdown = "@$username, A new OAuth provider has been linked to your account.\n\n
			**Provider:** {$providerName}\n
			**Time:** {$params['time']}\n
			**IP:** {$params['ip']}\n\n
			If you did not perform this action, please secure your account immediately by unlinking the provider and changing your password.";

			$message['body'][] = $parser->toHtml($markdown, $includeUnsubscribe, $unsubscribeUrl);
			mantle2_apply_list_headers($message, $params, $key);
			break;
		case 'oauth_provider_unlinked':
			$message['subject'] = 'The Earth App - OAuth Provider Unlinked';

			$providerName = ucfirst($params['provider'] ?? 'Unknown');
			$markdown = "@$username, An OAuth provider has been unlinked from your account.\n\n
			**Provider:** {$providerName}\n
			**Time:** {$params['time']}\n
			**IP:** {$params['ip']}\n\n
			If you did not perform this action, please secure your account immediately and re-link the provider if necessary.";

			$message['body'][] = $parser->toHtml($markdown, $includeUnsubscribe, $unsubscribeUrl);
			mantle2_apply_list_headers($message, $params, $key);
			break;
		case 'account_disabled':
			$message['subject'] = 'The Earth App - Account Disabled';

			$actor = $params['actor'] ?? 'an administrator';
			$time = $params['time'] ?? date(DATE_ATOM);
			$reason = $params['disable_reason'] ?? 'No reason provided';
			$markdown = "@$username, Your account has been disabled by {$actor}.\n\n
			**Time:** {$time}\n\n
			**Reason:** {$reason}\n\n
			If you believe this is a mistake, please contact support to appeal this action.";

			$message['body'][] = $parser->toHtml($markdown, false);
			break;
		case 'account_enabled':
			$message['subject'] = 'The Earth App - Account Re-enabled';

			$actor = $params['actor'] ?? 'an administrator';
			$time = $params['time'] ?? date(DATE_ATOM);
			$reason = $params['enable_reason'] ?? 'No reason provided';
			$markdown = "@$username, Your account has been re-enabled by {$actor}.\n\n
			**Time:** {$time}\n\n
			**Reason:** {$reason}\n\n
			You can now sign in again and continue using The Earth App.";

			$message['body'][] = $parser->toHtml($markdown, false);
			break;
		case 'account_deletion_warning':
			$window = $params['window'] ?? 'soon';
			$deleteAt = $params['delete_at'] ?? null;
			$message['subject'] = "The Earth App - Account Deletion in $window";

			$whenLine = $deleteAt ? "**Scheduled Deletion:** {$deleteAt}\n\n" : '';
			$markdown = "@$username, Your account has been inactive for nearly a year and is scheduled for permanent deletion in **{$window}**.\n\n
			{$whenLine}To keep your account and all of your data, simply sign in before then:\n
			https://app.earth-app.com\n\n
			If you do nothing, your account and all associated data will be permanently deleted. This cannot be undone.";

			$message['body'][] = $parser->toHtml($markdown, false);
			break;
		case 'account_deleted':
			$message['subject'] = 'The Earth App - Account Deleted';

			$markdown = "@$username, Your account has been permanently deleted after a prolonged period of inactivity.\n\n
			All associated data has been removed. If this was a mistake or you would like to come back, you're always welcome to create a new account at https://app.earth-app.com.\n\n
			Thank you for having been part of The Earth App.";

			$message['body'][] = $parser->toHtml($markdown, false);
			break;
		case 'content_moderation':
			$role = $params['role'] ?? 'author';
			$contentType = $params['content_type'] ?? 'content';
			$action = $params['action'] ?? '';
			$notes = $params['notes'] ?? '';

			if ($role === 'reporter') {
				$message['subject'] = 'The Earth App - Your Report Was Reviewed';
				$markdown = "@$username, thank you for your report. Our moderation team reviewed the $contentType you reported and has taken appropriate action.\n\n";
			} else {
				$message['subject'] = 'The Earth App - Content Moderation Notice';
				if ($action === 'ban_user') {
					$markdown = "@$username, your account has been suspended for violating our community guidelines.\n\n";
				} elseif ($action === 'delete_content') {
					$markdown = "@$username, your $contentType was removed for violating our community guidelines.\n\n";
				} else {
					$markdown = "@$username, a moderation decision was made regarding your $contentType.\n\n";
				}
			}

			if ($notes) {
				$markdown .= "**Note from moderators:** $notes\n\n";
			}
			$markdown .= 'If you believe this is a mistake, please contact support.';

			$message['body'][] = $parser->toHtml($markdown, false);
			break;
		case 'moderation_digest':
			$count = (int) ($params['count'] ?? 0);
			$message['subject'] = "The Earth App - $count Reports Awaiting Moderation";

			$markdown = "@$username, there are **$count** content report(s) awaiting moderation on The Earth App.\n\n
			Review them in the admin dashboard:\n
			https://app.earth-app.com/admin?tab=reports";

			$message['body'][] = $parser->toHtml($markdown, false);
			break;
		case 'plan_trial':
			$type = $params['type'] ?? 'Pro';
			$message['subject'] = "The Earth App - $type Trial Activated";

			$days = $params['days'] ?? 7;
			$markdown = "@$username, Your free trial for The Earth App $type has been activated.\n\n
			**Trial Period:** {$days} days\n
			**Time Remaining:** {$days} days\n\n
			Enjoy exploring the features of The Earth App! If you have any questions or need assistance, feel free to contact our support team.";

			$message['body'][] = $parser->toHtml($markdown, false);
			break;
		case 'plan_trial_warning':
			$type = $params['type'] ?? 'Pro';
			$message['subject'] = "The Earth App - $type Trial Ending Soon";

			$days = $params['days'] ?? 1;
			$markdown = "@$username, Your free trial for The Earth App $type is ending soon.\n\n
			**Time Remaining:** {$days} day(s)\n\n
			To keep your current features, please visit your account page to choose a plan before your trial ends.";

			$message['body'][] = $parser->toHtml($markdown, false);
			break;
		case 'plan_trial_expired':
			$type = $params['type'] ?? 'Pro';
			$message['subject'] = "The Earth App - $type Trial Expired";

			$markdown = "@$username, Your free trial for The Earth App $type has expired.\n\n
			We hope you enjoyed trying out the features! If you have any questions or would like to continue using The Earth App, please consider subscribing to one of our plans. Visit your account page for more details.";

			$message['body'][] = $parser->toHtml($markdown, false);
			break;
		case 'api_key_expiring':
			$keyName = $params['key_name'] ?? 'Unnamed key';
			$prefix = $params['key_prefix'] ?? '';
			$window = $params['window'] ?? 'soon';
			$expiresAt = isset($params['expires_at'])
				? gmdate('c', (int) $params['expires_at'])
				: null;
			$message['subject'] = "The Earth App - API Key Expiring $window";

			$expiresLine = $expiresAt ? "**Expires:** {$expiresAt}\n\n" : '';
			$markdown = "@$username, Your API key **{$keyName}** (`{$prefix}...`) will expire {$window}.\n\n
			{$expiresLine}If you still need this key, rotate it now from your account settings:\n
			https://app.earth-app.com/settings/api-keys\n\n
			If you no longer use this key you can ignore this email and it will expire automatically.";

			$message['body'][] = $parser->toHtml($markdown, false);
			break;
		case 'api_key_expired':
			$keyName = $params['key_name'] ?? 'Unnamed key';
			$prefix = $params['key_prefix'] ?? '';
			$expiresAt = isset($params['expires_at'])
				? gmdate('c', (int) $params['expires_at'])
				: null;
			$message['subject'] = 'The Earth App - API Key Expired';

			$expiresLine = $expiresAt ? "**Expired at:** {$expiresAt}\n\n" : '';
			$markdown = "@$username, Your API key **{$keyName}** (`{$prefix}...`) has expired.\n\n
			{$expiresLine}It can no longer authenticate requests. If you still need it, create a replacement from your account settings:\n
			https://app.earth-app.com/settings/api-keys";

			$message['body'][] = $parser->toHtml($markdown, false);
			break;
		case 'unread_notifications_reminder':
			/** @var array<Notification> $notifications */
			$notifications = is_array($params['notifications'] ?? null)
				? array_values(
					array_filter(
						$params['notifications'],
						fn($notification) => $notification instanceof Notification,
					),
				)
				: [];

			$count = (int) ($params['count'] ?? count($notifications));

			$message['subject'] = "You have $count unread notifications on The Earth App";

			$notificationsList = array_map(function ($notification) {
				$link =
					$notification->getLink() ?? '/profile/notifications/' . $notification->getId();
				if (!preg_match('/^https?:\/\//i', $link)) {
					$link =
						'https://app.earth-app.com' .
						(str_starts_with($link, '/') ? $link : '/' . $link);
				}
				$timestamp = date('Y-m-d H:i:s', $notification->getTimestamp());

				return '**' .
					$notification->getTitle() .
					'** from ' .
					$notification->getSource() .
					"\n\n" .
					$notification->getMessage() .
					"\n\n[View Notification](" .
					$link .
					")\n*" .
					$timestamp .
					"*\n\n";
			}, $notifications);

			$markdown =
				"@$username, You have **{$count}** unread notifications in The Earth App.\n\n" .
				implode("\n", $notificationsList);

			$shown = count($notifications);
			$more = $count - $shown;
			if ($more > 0) {
				$markdown .= "\n\n**{$more} more on The Earth App...** [View all](https://app.earth-app.com/profile/notifications)";
			}

			$markdown .=
				"\n\n\nDon't miss out on important updates and interactions! Visit your notifications page to stay informed and engaged with the community.";

			$message['body'][] = $parser->toHtml($markdown, false);
			break;
	}
}

function mantle2_mail_alter(&$message)
{
	$messages = [
		'mantle2_email_verification',
		'mantle2_login_verification',
		'mantle2_oauth_email_auto_set',
		'mantle2_welcome',
		'mantle2_quest_challenge',
		'mantle2_new_login',
		'mantle2_new_password',
		'mantle2_password_reset',
		'mantle2_email_change_notification',
		'mantle2_email_change_verification',
		'mantle2_email_change_confirmed',
		'mantle2_oauth_provider_linked',
		'mantle2_oauth_provider_unlinked',
		'mantle2_account_disabled',
		'mantle2_account_enabled',
		'mantle2_account_deletion_warning',
		'mantle2_account_deleted',
		'mantle2_plan_trial',
		'mantle2_plan_trial_warning',
		'mantle2_plan_trial_expired',
		'mantle2_unread_notifications_reminder',
		'mantle2_api_key_expiring',
		'mantle2_api_key_expired',
	];

	if (
		in_array($message['id'], $messages, true) ||
		str_starts_with($message['id'], 'mantle2_campaign:')
	) {
		$message['headers']['Content-Type'] = 'text/html; charset=UTF-8';
		$message['params']['convert'] = false;
	}

	// Add List-Unsubscribe headers for campaign emails
	if (str_starts_with($message['id'], 'mantle2_campaign:')) {
		$campaignId = substr($message['id'], strlen('mantle2_campaign:'));
		mantle2_apply_list_headers($message, $message['params'] ?? [], $campaignId);
		$message['headers']['Precedence'] = 'bulk';
	}

	// Add List-Unsubscribe headers for specific email types
	$unsubscribableMessages = [
		'mantle2_new_login',
		'mantle2_new_password',
		'mantle2_oauth_provider_linked',
		'mantle2_oauth_provider_unlinked',
	];
	if (in_array($message['id'], $unsubscribableMessages, true)) {
		$listId = str_starts_with($message['id'], 'mantle2_')
			? substr($message['id'], strlen('mantle2_'))
			: $message['id'];
		mantle2_apply_list_headers($message, $message['params'] ?? [], $listId);
	}
}

// hourly implementation
function mantle2_cron()
{
	$lock = Drupal::lock();
	$lockName = 'mantle2.cron';

	// short TTL so a hard-killed cron self-heals
	if (!$lock->acquire($lockName, 600)) {
		Drupal::logger('mantle2')->warning('[cron] Previous cron still running.');
		return;
	}

	// no-op under most web SAPIs but real on CLI; harmless either way
	@set_time_limit(3600);
	// keep running if the triggering web request is aborted by the client
	@ignore_user_abort(true);

	$state = ['released' => false, 'normal' => false];
	$release = function () use ($lock, $lockName, &$state) {
		if ($state['released']) {
			return;
		}
		$state['released'] = true;

		if (!$state['normal']) {
			try {
				Drupal::logger('mantle2')->error(
					'[cron] shutdown handler releasing lock — cron did not finish normally',
				);
			} catch (Throwable) {
				// best-effort during shutdown
			}
		}

		try {
			$lock->release($lockName);
		} catch (Throwable) {
			// best-effort during shutdown
		}
	};
	register_shutdown_function($release);

	try {
		$tasks = [
			'Expired Prompts' => fn() => PromptsHelper::checkExpiredPrompts(),
			'Expired Articles' => fn() => ArticlesHelper::checkExpiredArticles(),
			'Expired Events' => fn() => EventsHelper::checkExpiredEvents(),
			'Email Campaigns' => fn() => CampaignHelper::runEmailCampaigns(),
			'Event Notifications' => fn() => EventsHelper::checkEventNotifications(),
			'Fix Event Dates' => fn() => mantle2_fix_event_dates(),
			'User Badges' => fn() => UsersHelper::checkBadges(),
			'Account Trials' => fn() => UsersHelper::checkAccountTrials(),
			'Inactive Accounts' => fn() => UsersHelper::checkInactiveAccounts(),
			'Disabled Account Restrictions' => fn() => UsersHelper::enforceDisabledAccountRestrictions(),
			'Moderation Digest' => fn() => ReportsHelper::runDailyDigest(),
			'Reenable Disabled Accounts' => fn() => ReportsHelper::reenableExpiredDisables(),
			'Unread Notifications' => fn() => UsersHelper::checkUnreadNotifications(),
			'Stale Push Tokens' => fn() => UsersHelper::pruneStalePushTokens(),
			'API Key Expirations' => fn() => ApiKeysHelper::checkExpirations(),
			'Cycle MOTD' => fn() => GeneralHelper::cycleMotd(),
		];

		foreach ($tasks as $label => $task) {
			try {
				$start = microtime(true);
				$task();
				$duration = round(microtime(true) - $start, 2);

				Drupal::logger('mantle2')->notice('[cron] Task completed: @task (@seconds sec)', [
					'@task' => $label,
					'@seconds' => $duration,
				]);
			} catch (Throwable $e) {
				Drupal::logger('mantle2')->error('[cron] Task failed: @task :: @message', [
					'@task' => $label,
					'@message' => $e->getMessage(),
				]);
			}
		}

		$state['normal'] = true;
		Drupal::logger('mantle2')->notice('[cron] mantle2 cron finished.');
	} finally {
		// normal path + any uncaught throwable that escapes the task loop
		$release();
	}
}

function mantle2_fix_event_dates(): void
{
	try {
		$storage = Drupal::entityTypeManager()->getStorage('node');
		$query = $storage
			->getQuery()
			->condition('type', 'event')
			->condition('status', 1)
			->accessCheck(false);

		$nids = $query->execute();
		if (empty($nids)) {
			return;
		}

		$fixed_count = 0;
		$threshold_date = '2000-01-01T00:00:00'; // Dates before year 2000 are invalid

		foreach ($nids as $nid) {
			$node = Drupal\node\Entity\Node::load($nid);
			if (!$node) {
				continue;
			}

			$needs_update = false;

			$date_value = $node->get('field_event_date')->value;
			if ($date_value && $date_value < $threshold_date) {
				// Date is in seconds, convert to milliseconds (multiply by 1000)
				$timestamp_seconds = strtotime($date_value);
				$timestamp_millis = $timestamp_seconds * 1000;
				$new_date = date('Y-m-d\TH:i:s', $timestamp_millis / 1000);
				$node->set('field_event_date', $new_date);
				$needs_update = true;
			}

			$end_date_value = $node->get('field_event_enddate')->value;
			if ($end_date_value && $end_date_value < $threshold_date) {
				// Date is in seconds, convert to milliseconds (multiply by 1000)
				$timestamp_seconds = strtotime($end_date_value);
				$timestamp_millis = $timestamp_seconds * 1000;
				$new_end_date = date('Y-m-d\TH:i:s', $timestamp_millis / 1000);
				$node->set('field_event_enddate', $new_end_date);
				$needs_update = true;
			}

			if ($needs_update) {
				$node->save();
				$fixed_count++;
			}
		}

		if ($fixed_count > 0) {
			Drupal::logger('mantle2')->notice(
				'[cron] Fixed %count event(s) with malformed dates.',
				['%count' => $fixed_count],
			);
		}
	} catch (Exception $e) {
		Drupal::logger('mantle2')->error('[cron] Failed to fix event dates: %message', [
			'%message' => $e->getMessage(),
		]);
	}
}
